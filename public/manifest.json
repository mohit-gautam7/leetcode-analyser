{
  "manifest_version": 3,
  "name": "CodeSense AI",
  "version": "1.1.0",
  "description": "AI-powered coding assistant for LeetCode, Codeforces, GeeksForGeeks and 7 more platforms",
  "permissions": ["storage", "activeTab", "scripting", "sidePanel", "tabs"],
  "host_permissions": [
    "https://*.leetcode.com/*",
    "https://www.geeksforgeeks.org/*",
    "https://practice.geeksforgeeks.org/*",
    "https://geeksforgeeks.org/*",
    "https://*.codeforces.com/*",
    "https://www.codechef.com/*",
    "https://*.atcoder.jp/*",
    "https://www.hackerrank.com/*",
    "https://*.codingninjas.com/*",
    "https://www.naukri.com/code360/*",
    "https://www.interviewbit.com/*",
    "https://cses.fi/*",
    "https://www.spoj.com/*",
    "https://integrate.api.nvidia.com/*",
    "https://openrouter.ai/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*",
        "https://leetcode.com/contest/*",
        "https://practice.geeksforgeeks.org/problems/*",
        "https://www.geeksforgeeks.org/problems/*",
        "https://geeksforgeeks.org/problems/*",
        "https://codeforces.com/problemset/problem/*/*",
        "https://codeforces.com/contest/*/problem/*",
        "https://codeforces.com/gym/*/problem/*",
        "https://www.codechef.com/problems/*",
        "https://www.codechef.com/*/problems/*",
        "https://atcoder.jp/contests/*/tasks/*",
        "https://www.hackerrank.com/challenges/*",
        "https://www.hackerrank.com/contests/*",
        "https://www.codingninjas.com/studio/problems/*",
        "https://www.naukri.com/code360/problems/*",
        "https://www.interviewbit.com/problems/*",
        "https://cses.fi/problemset/task/*",
        "https://www.spoj.com/problems/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "CodeSense AI"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["sidebar.html", "assets/*", "chunks/*", "*.css", "*.js", "data/*.json"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+A",
        "mac": "MacCtrl+Shift+A"
      },
      "description": "Open CodeSense AI"
    }
  }
}
